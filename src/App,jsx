import { useState, useEffect, useCallback, useRef } from "react";
import { db } from "./firebase";
import { doc, getDoc, setDoc } from "firebase/firestore";

const uid  = () => Math.random().toString(36).slice(2, 8);
const num  = v  => parseFloat(v) || 0;
const fmt  = v  => { const n = parseFloat(v); if (!n && n !== 0) return "—"; return "₹" + Math.abs(n).toLocaleString("en-IN"); };
const today   = () => new Date().toISOString().split("T")[0];
const prevDay = d  => { const dt = new Date(d); dt.setDate(dt.getDate() - 1); return dt.toISOString().split("T")[0]; };
const dDisplay = s => { if (!s) return ""; const [y, m, d] = s.split("-"); return `${d}/${m}/${y}`; };

const DENOMS = [500, 200, 100, 50, 20, 10];
const mkDenomCounts = () => Object.fromEntries(DENOMS.map(d => [d, 0]));
const mkAccount  = (name = "") => ({ id: uid(), name, open: "", close: "" });
const mkExpense  = ()          => ({ id: uid(), name: "", amount: "" });
const mkCredit   = ()          => ({ id: uid(), name: "", amount: "" });
const mkVoucher  = ()          => ({ id: uid(), name: "", amount: "" });

const defaultData = () => ({
  accounts: [
    mkAccount("KO"), mkAccount("SBI OD PS"), mkAccount("SBI SB PS"),
    mkAccount("CA SBI"), mkAccount("INDIRA SBI"), mkAccount("BY CASH"),
    mkAccount("COINS"), mkAccount("MPS"), mkAccount("ANJILE"),
    mkAccount("PAY POINT"), mkAccount("MARCHANT"), mkAccount("PSR"),
  ],
  expenses:    [mkExpense()],
  credits:     [mkCredit()],
  vouchers:    [mkVoucher()],
  denomCounts: mkDenomCounts(),
  notes:       "",
});

// ── Firebase helpers ──────────────────────────────────────────────────────────
const COLLECTION = "ledger";

async function fbGet(date) {
  try {
    const snap = await getDoc(doc(db, COLLECTION, date));
    if (snap.exists()) return snap.data();
  } catch (e) { console.error("fbGet", e); }
  return null;
}

async function fbSet(date, data) {
  try {
    await setDoc(doc(db, COLLECTION, date), data);
    return true;
  } catch (e) { console.error("fbSet", e); return false; }
}

